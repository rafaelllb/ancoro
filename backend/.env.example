# =================================================
# Ancoro Backend - Configuração de Ambiente
# =================================================
# Copie este arquivo para .env.{ambiente} e ajuste os valores
# Ambientes suportados: demo, development, staging, production

# Ambiente atual
NODE_ENV=development

# Porta do servidor
PORT=3000

# =================================================
# DATABASE
# =================================================
# SQLite (dev/demo): file:./dev.db ou file:./demo.db
# PostgreSQL (staging/prod): postgresql://user:password@host:5432/database
DATABASE_URL="file:./dev.db"

# =================================================
# AUTENTICAÇÃO
# =================================================
# JWT Secret - MÍNIMO 32 caracteres em produção!
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="dev_secret_change_in_production_min_32_chars"
JWT_EXPIRES_IN="7d"

# =================================================
# MODO DEMO
# =================================================
# DEMO_MODE=true ativa modo demonstração independente de NODE_ENV
DEMO_MODE=false
# DEMO_AUTO_SEED=true popula banco automaticamente no startup
DEMO_AUTO_SEED=false

# =================================================
# LOGGING
# =================================================
# Níveis: debug, info, warn, error
LOG_LEVEL=info

# =================================================
# CORS
# =================================================
# Em produção, especifique o domínio exato: https://app.Ancoro.com
CORS_ORIGIN="*"
