{
  "name": "Ancoro-backend",
  "version": "1.0.0",
  "description": "Backend API for Ancoro Application",
  "main": "dist/index.js",
  "scripts": {
    "dev": "dotenv -e .env.development -- nodemon src/index.ts",
    "dev:demo": "dotenv -e .env.demo -- nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:staging": "dotenv -e .env.staging -- node dist/index.js",
    "start:prod": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:prod": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "dotenv -e .env.development -- ts-node prisma/seed.ts",
    "prisma:seed:demo": "dotenv -e .env.demo -- ts-node prisma/seed.ts",
    "test": "jest"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [
    "sap",
    "utilities",
    "lean",
    "express",
    "prisma"
  ],
  "author": "Rafael Brito",
  "license": "UNLICENSED",
  "dependencies": {
    "@prisma/client": "^5.9.1",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.9.1",
    "socket.io": "^4.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5",
    "dotenv-cli": "^7.4.4",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
