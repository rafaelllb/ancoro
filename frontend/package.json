{
  "name": "Ancoro-frontend",
  "private": true,
  "version": "1.0.0",
  "description": "Frontend Electron + React for Ancoro Application",
  "author": "Rafael Brito",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --mode development",
    "dev:demo": "vite --mode demo",
    "build": "tsc -p tsconfig.electron.json && tsc && vite build --mode production",
    "build:staging": "tsc -p tsconfig.electron.json && tsc && vite build --mode staging",
    "build:demo": "tsc -p tsconfig.electron.json && tsc && vite build --mode demo",
    "preview": "vite preview",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:dev": "npm run electron:compile && concurrently \"vite --mode development\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:demo": "npm run electron:compile && concurrently \"vite --mode demo\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.17.19",
    "@tanstack/react-table": "^8.11.6",
    "axios": "^1.6.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.21.1",
    "recharts": "^2.10.3",
    "socket.io-client": "^4.6.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.1.4",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.rafaelbrito.Ancoro",
    "productName": "Ancoro App",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png"
    }
  }
}
