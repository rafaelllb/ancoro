# =================================================
# Ancoro Frontend - Configuração de Ambiente
# =================================================
# Copie este arquivo para .env.{ambiente} e ajuste os valores
# Ambientes suportados: demo, development, staging, production

# URL da API Backend
VITE_API_URL=http://localhost:3000

# Ambiente atual (demo | development | staging | production)
VITE_APP_ENV=development

# Modo demo (true/false) - ativa funcionalidades de demonstração
VITE_DEMO_MODE=false

# Mostrar indicador de ambiente na UI (true/false)
VITE_SHOW_ENV_INDICATOR=true
